# =============================================================================
# StellarGive — Root environment variables
#
# Copy this file to .env and fill in the values for your environment.
# Variables prefixed NEXT_PUBLIC_ are safe to expose to the browser bundle;
# all others are server-side / script-only.
#
#   cp .env.example .env
#   cp .env.example frontend/.env.local   # also copy to the frontend
# =============================================================================

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Stellar network to target: testnet | mainnet
STELLAR_NETWORK=testnet

# Soroban JSON-RPC endpoint for the target network.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban-mainnet.stellar.org  (or your own node)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — must match STELLAR_NETWORK.
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ---------------------------------------------------------------------------
# Contract
# ---------------------------------------------------------------------------

# Deployed StellarGive contract ID (written automatically by deploy-contract.sh).
# Set this manually if you are targeting an already-deployed contract.
CONTRACT_ID=

# ---------------------------------------------------------------------------
# Scripts
# ---------------------------------------------------------------------------

# Stellar CLI key alias used by deploy-contract.sh as the fee-paying source.
# Generate one with: stellar keys generate --global deployer
DEPLOYER_ALIAS=deployer

# Timeout (milliseconds) for RPC health-check requests (monitor-rpc.js).
RPC_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Alerting (rpc-health monitor)
# ---------------------------------------------------------------------------

# Slack incoming-webhook URL — if set, monitor-rpc.js posts alerts here.
# Leave blank to disable Slack alerts.
SLACK_WEBHOOK_URL=

# Discord webhook URL — if set, monitor-rpc.js posts alerts here.
# Leave blank to disable Discord alerts.
DISCORD_WEBHOOK_URL=

# GitHub token with `issues:write` scope — used by rpc-health.yml to
# open/close tracking issues on outage.  Set as a repo secret in CI.
# GITHUB_TOKEN is automatically provided in GitHub Actions; only needed locally.
# GH_ALERT_TOKEN=

# GitHub repo slug for alert-issue tracking (owner/repo).
ALERT_REPO=Feyisara2108/stellargive

# ---------------------------------------------------------------------------
# Mainnet dry-run (deploy-dry-run.sh)
# ---------------------------------------------------------------------------

# Mainnet RPC URL — only required when running deploy-dry-run.sh.
# MAINNET_RPC_URL=https://soroban-mainnet.stellar.org
# MAINNET_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
