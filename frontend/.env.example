# =============================================================================
# StellarGive Frontend — environment variables
#
# Copy to frontend/.env.local and fill in the values:
#   cp frontend/.env.example frontend/.env.local
#
# Variables prefixed NEXT_PUBLIC_ are embedded in the browser bundle.
# Never put secrets in NEXT_PUBLIC_ variables.
# =============================================================================

# ---------------------------------------------------------------------------
# Contract
# ---------------------------------------------------------------------------

# Deployed StellarGive contract ID.
# Automatically written by scripts/deploy-contract.sh after a successful deploy.
NEXT_PUBLIC_CONTRACT_ID=CB6HVHRQYILGNKW7RBB66BC6TDBIEWADOA2YUUV4I22RXRLA6DY6OAKT

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Soroban RPC endpoint.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban-mainnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase — must match the RPC network above.
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Sentry DSN — leave blank to disable error reporting in the browser.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-plugin credentials (server-side; used during `next build`).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Application version tag surfaced in Sentry releases.
NEXT_PUBLIC_APP_VERSION=

# ---------------------------------------------------------------------------
# Private / server-side only
# ---------------------------------------------------------------------------
# Never prefix secrets with NEXT_PUBLIC_ — they would be exposed to all users.
# ADMIN_SECRET_KEY=
